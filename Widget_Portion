def draw_dashboard():
    canvas4.delete("all")
    try:
        data = pd.read_csv("data.csv", dtype=str)
    except FileNotFoundError:
        data = pd.DataFrame(columns=["status", "company", "last_update"])
    data = data.fillna('')

    #calculate totals
    total = len(data)
    interviews = len(data[data["status"] == "interview"])
    rejected = len(data[data["status"] == "denied"])
    offered = len(data[data["status"] == "offered"])
    applied = len(data[data["status"] == "applied"])

    # Top Banner 
    banner_height = 70
    canvas4.create_rectangle(0, 0, square_size, banner_height, fill="#254236", outline="")

    # KPIs as percentage-only blocks with labels 
    kpi_width = 80
    kpi_height = 40
    kpi_spacing = 15
    x_start = 10
    y_start = 15  

    kpis = [
        ("Total", applied, "#374F47"),
        ("Interview", interviews, "#839958"),
        ("Offers", offered, "#F7F4D5"),
        ("Rejected", rejected, "#EC9C9D")
    ]

    for i, (label, val, color) in enumerate(kpis):
        x0 = x_start + i*(kpi_width + kpi_spacing)
        y0 = y_start
        x1 = x0 + kpi_width
        y1 = y0 + kpi_height
        canvas4.create_rectangle(x0, y0, x1, y1, fill=color, outline="", width=2)
        percent = f"{(val/total*100):.1f}%" if total > 0 else "0%"

        # KPI label 
        canvas4.create_text((x0+x1)//2, y0 + 12, text=label, font=("Arial", 8, "bold"), fill="black")
        canvas4.create_text((x0+x1)//2, y0 + 28, text=f"{percent}", font=("Arial", 10, "bold"), fill="black")

    # Flowchart blocks
    block_width, block_height = 80, 35
    gap = 50
    x_start, y_start = 30, banner_height + 30  # starting below the banner

    # Applied
    canvas4.create_rectangle(x_start, y_start, x_start+block_width, y_start+block_height, fill="#374F47", outline="black")
    canvas4.create_text(x_start+block_width/2, y_start+block_height/2,
                        text=f"Applied\n{applied}", font=("Arial", 8))

    # Arrow to Interview
    x_interview = x_start + block_width + gap
    canvas4.create_line(x_start+block_width, y_start+block_height/2, x_interview, y_start+block_height/2, arrow=tk.LAST)

    # Interview
    canvas4.create_rectangle(x_interview, y_start, x_interview+block_width, y_start+block_height, fill="#839958", outline="black")
    canvas4.create_text(x_interview+block_width/2, y_start+block_height/2,
                        text=f"Interview\n{interviews}", font=("Arial", 8))

    # Arrow to Offer and Denied
    x_offer = x_interview + block_width + gap
    y_offer = y_start
    canvas4.create_line(x_interview+block_width, y_start+block_height/2, x_offer, y_start+block_height/2 - 10, arrow=tk.LAST)
    canvas4.create_line(x_interview+block_width, y_start+block_height/2, x_offer, y_start+block_height/2 + 10, arrow=tk.LAST)

    # Offer
    canvas4.create_rectangle(x_offer, y_offer-10, x_offer+block_width, y_offer+block_height-10, fill="#F7F4D5", outline="black")
    canvas4.create_text(x_offer+block_width/2, y_offer+block_height/2-10,
                        text=f"Offered\n{offered}", font=("Arial", 8))

    # Denied
    canvas4.create_rectangle(x_offer, y_offer+40, x_offer+block_width, y_offer+block_height+40, fill="#EC9C9D", outline="black")
    canvas4.create_text(x_offer+block_width/2, y_offer+block_height/2+40,
                        text=f"Rejected\n{rejected}", font=("Arial", 8))

    #Bottom Mini dashboard 
    bottom_y = y_offer + 100
    bar_width = 140
    bar_height = 12
    spacing = 8
    x_left = 20

    status_list = [("Applied", applied, "#374F47"),
                   ("Interview", interviews, "#839958"),
                   ("Offered", offered, "#F7F4D5"),
                   ("Rejected", rejected, "#EC9C9D")]

    canvas4.create_text(70, bottom_y-10, text="Status Overview", font=("Arial", 10, "bold"))

    for i, (label, val, color) in enumerate(status_list):
        y_pos = bottom_y + i*(bar_height+spacing)
        canvas4.create_text(x_left, y_pos + bar_height/2, text=f"{label}", anchor="w", font=("Arial", 9))
        canvas4.create_rectangle(x_left+80, y_pos, x_left+80+bar_width, y_pos+bar_height, fill="#eee", outline="")
        fill_width = (val/total*bar_width) if total > 0 else 0
        canvas4.create_rectangle(x_left+80, y_pos, x_left+80+fill_width, y_pos+bar_height, fill=color, outline="")

    #Recent Updates
    last_updates = data.sort_values("last_update", ascending=False).head(3) if "last_update" in data.columns else pd.DataFrame()
    updates_text = "\n".join([f"{row['company']} → {row['status']} ({row['last_update']})" 
                              for _, row in last_updates.iterrows()]) if not last_updates.empty else "No recent updates"
    canvas4.create_text(200, bottom_y + 95, text="Recent Updates:\n"+updates_text,
                        font=("Arial", 9), anchor="n", justify="center")

# Drawing the finalized dashboard
draw_dashboard()
    
