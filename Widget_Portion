# Resizable Pop-up Report
def show_report():
    try:
        df = pd.read_csv("data.csv", dtype=str)
    except FileNotFoundError:
        messagebox.showwarning("Error", "No data available")
        return

    df = df.fillna('')

    # Column widths for alignment
    col_widths = {
        "date_applied": 12,
        "company": 20,
        "role": 20,
        "status": 15,
        "last_update": 15,
        "note": 25
    }

    # Header
    header = f"{'Date':<{col_widths['date_applied']}}" \
             f"{'Company':<{col_widths['company']}}" \
             f"{'Role':<{col_widths['role']}}" \
             f"{'Status':<{col_widths['status']}}" \
             f"{'Last Update':<{col_widths['last_update']}}" \
             f"{'Note':<{col_widths['note']}}"

    report_lines = [header, "-"*110]

    # Data rows
    for _, row in df.iterrows():
        line = f"{row.get('date_applied',''):<{col_widths['date_applied']}}" \
               f"{row.get('company',''):<{col_widths['company']}}" \
               f"{row.get('role',''):<{col_widths['role']}}" \
               f"{row.get('status',''):<{col_widths['status']}}" \
               f"{row.get('last_update',''):<{col_widths['last_update']}}" \
               f"{row.get('note',''):<{col_widths['note']}}"
        report_lines.append(line)

    report_text = "\n".join(report_lines)

    # Create resizable popup window
    report_win = tk.Toplevel(root)
    report_win.title("Application Report")
    report_win.geometry("900x500")  # bigger window so the alignment finally looks good
    report_win.minsize(700, 400)    # resizable limits

    # Text widget with monospaced font for proper alignment
    txt = tk.Text(report_win, font=("Courier New", 10), wrap="none")
    txt.pack(expand=True, fill="both")

    # Add horizontal and vertical scrollbars
    x_scroll = tk.Scrollbar(report_win, orient='horizontal', command=txt.xview)
    x_scroll.pack(side='bottom', fill='x')
    y_scroll = tk.Scrollbar(report_win, orient='vertical', command=txt.yview)
    y_scroll.pack(side='right', fill='y')
    txt.configure(xscrollcommand=x_scroll.set, yscrollcommand=y_scroll.set)

    txt.insert(tk.END, report_text)
    txt.config(state='disabled')  # make read-only

# Report button
tk.Button(slide3, text="Report", bg="#3b775e", fg="black", command=show_report).place(x=230, y=280)

